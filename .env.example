# ================================================
# KONFIGURACJA ŚRODOWISKA - SZTAB WAWAKA
# Skopiuj ten plik jako .env i uzupełnij wartości
# ================================================

# Port na którym działa serwer Node.js (za Nginx nie zmieniaj)
PORT=3000

# Tajny klucz do podpisywania tokenów JWT
# WAŻNE: zmień na long random string przed wdrożeniem!
# Możesz wygenerować: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ZMIEN_NA_LOSOWY_DLUGI_CIAG_ZNAKOW

# Środowisko (production / development)
NODE_ENV=production
